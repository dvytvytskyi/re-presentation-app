generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Presentation {
  id        String   @id @default(cuid())
  name      String
  data      String   // Using String for SQLite to store JSON stringified
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?  // For future auth
}
